# ── Plantilla de producción. Copiar a server/.env.production y rellenar. ────
#    cp server/.env.production.example server/.env.production
#  NO commitear server/.env.production (lleva secretos reales).

# ── Servidor ──
PORT=3001
NODE_ENV=production
DATA_DIR=/data                 # aquí viven .db_secret y .jwt_secret (volumen backend-data)

# ── MySQL/MariaDB ── (backend host-mode → MariaDB publicada en 127.0.0.1:3307)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=vpn_app
MYSQL_PASSWORD=<IGUAL_QUE_DB_APP_PASSWORD_DEL_.env_RAIZ>
MYSQL_DATABASE=vpn_manager
MYSQL_POOL=10

# ── CORS ── (origen real del panel; despliegue IP+HTTPS autofirmado)
CORS_ORIGINS=https://134.199.212.232

# ── URL pública del frontend (para emails/invitaciones) ──
APP_BASE_URL=https://134.199.212.232/GestionVPN-1.0/

# ── IP pública FIJA del MikroTik (para los .conf WireGuard de los usuarios) ──
#    Es la IP pública del ROUTER (no la del VPS, que es 134.199.212.232).
WG_PUBLIC_IP=213.173.36.232

# ── Jobs de fondo ──
EXPIRATION_JOB_ENABLED=true
MONITORING_ENABLED=true
AP_POLL_ENABLED=true

# ── Rate limit de login ──
RL_MAX_FAILS=5
RL_WINDOW_MS=900000

# ── Métricas Prometheus solo locales ──
METRICS_ALLOW_REMOTE=0

# ── Opción C: pool de scan-IPs del VPS (escaneo + Monitor AP multi-VRF) ──
#   El pool vive en 10.11.251.0/24: un /24 DEDICADO que NO debe coincidir con
#   ninguna LAN de torre (192.168.30.0/24 era una LAN real de ND7/ND16 → chocaba).
#   Requiere: pool en wg0 del VPS + allowed-address del peer VPS en MikroTik +
#   ruta de retorno por VRF (SCAN_RETURN_SUBNET, abajo).
SCAN_IP_POOL_BASE=10.11.251.
SCAN_IP_POOL_START=2
SCAN_IP_POOL_END=254
# /24 de scan-IP para el que provision.routes añade ruta de retorno en cada VRF.
# Déjalo VACÍO si las scan-IP estuvieran dentro de 192.168.21.0/24.
SCAN_RETURN_SUBNET=10.11.251.0/24

# ── SMTP (Gmail App Password) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=fernandodiazm.5@gmail.com
SMTP_PASS=<APP_PASSWORD_16_CHARS>
SMTP_FROM=MikroTik VPN <fernandodiazm.5@gmail.com>

# ── Telegram ──
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=<TOKEN_DEL_BOT>
