# ── Servidor ──
PORT=3001
NODE_ENV=development
DATA_DIR=.

# ── MySQL (XAMPP) — Fase 1 multi-usuario / RBAC ──
# Por defecto XAMPP usa root sin contraseña en 127.0.0.1:3306
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=vpn_manager
MYSQL_POOL=10

# ── CORS (orígenes permitidos, separados por coma) ──
# CORS_ORIGINS=http://localhost:5173

# ── Sesión JWT (Fase 2) ──
JWT_EXPIRES=8h

# ── Rate limiting anti fuerza bruta (Fase 2) ──
RL_MAX_FAILS=5
RL_WINDOW_MS=900000

# ── SMTP para OTP (Fase 2) — OPCIONAL ──
# Sin SMTP configurado, el OTP se imprime en consola (modo dev).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASS=tu_contraseña_de_aplicacion
# SMTP_FROM=MikroTik VPN <no-reply@tudominio.com>
