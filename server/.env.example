# ── Servidor ──
PORT=3001
NODE_ENV=development
DATA_DIR=.

# ── MySQL (XAMPP) — Fase 1 multi-usuario / RBAC ──
# Por defecto XAMPP usa root sin contraseña en 127.0.0.1:3306
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=vpn_manager
MYSQL_POOL=10

# ── CORS (orígenes permitidos, separados por coma) ──
# CORS_ORIGINS=http://localhost:5173

# ── Sesión JWT (Fase 2) ──
JWT_EXPIRES=8h

# ── Rate limiting anti fuerza bruta (Fase 2) ──
RL_MAX_FAILS=5
RL_WINDOW_MS=900000

# ── URL pública del frontend (usada en los links de invitación) ──
# Ajusta al dominio real en producción (ej: https://vpn.tuempresa.com/GestionVPN-1.0/)
APP_BASE_URL=http://localhost:5173/GestionVPN-1.0/

# ── IP pública FIJA del MikroTik (Endpoint de WireGuard) ──
# Sobrescribe lo que reporta /ip/cloud/print del router. Útil cuando:
#  • El router está detrás de NAT
#  • Tienes IP pública estática y no quieres depender de cloud
#  • El cloud reporta una IP distinta a la que se debe usar
# Si la dejas vacía, el server hace auto-discover desde el router.
# WG_PUBLIC_IP=213.173.36.232

# ── SMTP para OTP e invitaciones — OPCIONAL ──
# Sin SMTP configurado, el OTP/invitación se imprime en consola (modo dev).
#
# ▼ GMAIL: cómo obtener el App Password (NO es tu contraseña normal):
#   1. Ve a https://myaccount.google.com/security
#   2. Activa "Verificación en 2 pasos" (obligatorio)
#   3. Ve a https://myaccount.google.com/apppasswords
#   4. Crea una contraseña de aplicación llamada "VPN Manager"
#   5. Pega los 16 caracteres en SMTP_PASS (sin espacios)
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tucorreo@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# SMTP_FROM=MikroTik VPN <tucorreo@gmail.com>
