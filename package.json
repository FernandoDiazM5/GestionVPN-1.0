{
  "name": "mikrotik-vpn-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Panel SaaS multi-tenant para gestión de túneles VPN sobre MikroTik (SSTP + WireGuard) y monitoreo de equipos Ubiquiti airOS.",
  "repository": {
    "type": "git",
    "url": "https://github.com/FernandoDiazM5/GestionVPN-1.0"
  },
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*",
    "server",
    "vpn-manager"
  ],
  "scripts": {
    "prepare": "husky || true",
    "build:contracts": "npm run build --workspace=@gestionvpn/contracts",
    "check:backend": "cd server && node --check index.js && node -e \"['./auth.routes.js','./routes/account.routes.js','./routes/admin.routes.js','./routes/team.routes.js','./routes/workspace.routes.js','./routes/core/index.js','./routes/core/_shared.js','./routes/core/connection.routes.js','./routes/core/ppp.routes.js','./routes/core/interface.routes.js','./routes/core/tunnel.routes.js','./routes/core/tunnel-repair.routes.js','./routes/nodes/index.js','./routes/nodes/_shared.js','./routes/nodes/listing.routes.js','./routes/nodes/provision.routes.js','./routes/nodes/editing.routes.js','./routes/nodes/tags.routes.js','./routes/nodes/credentials.routes.js','./routes/nodes/history.routes.js','./routes/nodes/scan.routes.js','./routes/wireguard.routes.js','./routes/settings.routes.js','./routes/device.routes.js','./routes/events.routes.js','./routes/audit.routes.js','./routes/health.routes.js'].forEach(f=>require('child_process').execSync('node --check '+f,{stdio:'inherit'}));\"",
    "check:frontend": "cd vpn-manager && npx tsc --noEmit",
    "lint:frontend": "cd vpn-manager && npx eslint .",
    "check:all": "npm run check:backend && npm run check:frontend && npm run lint:frontend",
    "test:backend": "npm test --prefix server",
    "test:frontend": "npm test --prefix vpn-manager",
    "test:all": "npm run test:backend && npm run test:frontend",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "audit:design": "node scripts/audit-design.js",
    "audit:design:json": "node scripts/audit-design.js --json"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "vpn-manager/src/**/*.{ts,tsx}": [
      "npx eslint --config vpn-manager/eslint.config.js --fix"
    ],
    "server/**/*.js": [
      "node --check"
    ]
  }
}
