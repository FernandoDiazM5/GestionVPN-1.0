# ── Variables para docker-compose.prod.yml. Copiar a .env y rellenar. ───────
#    cp .env.prod.example .env   &&   chmod 600 .env
#  NO commitear .env.

# Contraseña root de MariaDB (solo para administración/backups)
DB_ROOT_PASSWORD=<root_segura_distinta>

# Contraseña del usuario de la app. DEBE coincidir con MYSQL_PASSWORD de server/.env.production
DB_APP_PASSWORD=<app_segura>
